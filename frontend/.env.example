# Copy to .env and fill in values. Never commit .env.
# Expo exposes client-safe vars with EXPO_PUBLIC_ prefix.
# https://docs.expo.dev/guides/environment-variables/

# Firebase (Web SDK config — Phase 1)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Maps (Phase 2 — route tracking)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Weather — live tracker uses Open-Meteo (no API key). See features/session-tracking/services/weather.ts
