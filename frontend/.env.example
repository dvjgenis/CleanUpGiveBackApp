# Copy to .env and fill in values. Never commit .env.
# Expo exposes client-safe vars with EXPO_PUBLIC_ prefix.
# https://docs.expo.dev/guides/environment-variables/

# Supabase (sessions + geolocation) — Dashboard → Settings → API
# Project URL only (https://YOUR_REF.supabase.co) — do NOT append /rest/v1
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Fly sessions API (set after deploy)
EXPO_PUBLIC_API_URL=https://cleanup-sessions.fly.dev

# Optional: shorten free-hour trial for QA (seconds; default 3600)
# EXPO_PUBLIC_FREE_TRIAL_SECONDS=120

# Weather — live tracker uses Open-Meteo (no API key).
# See features/session-tracking/services/weather.ts
