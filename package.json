{
  "name": "cleanup-giveback",
  "private": true,
  "description": "Clean Up - Give Back monorepo (frontend Expo app + backend services)",
  "scripts": {
    "start": "npm --prefix frontend start",
    "start:tunnel": "npm --prefix frontend run start:tunnel",
    "start:lan": "npm --prefix frontend run start:lan",
    "start:device": "npm --prefix frontend run start:device",
    "ios": "npm --prefix frontend run ios",
    "android": "npm --prefix frontend run android",
    "web": "npm --prefix frontend run web",
    "lint": "npm --prefix frontend run lint",
    "typecheck": "npm --prefix frontend exec -- tsc --noEmit"
  },
  "dependencies": {
    "expo": "^57.0.7"
  },
  "devDependencies": {
    "@types/react": "~19.2.4",
    "typescript": "~6.0.3"
  }
}
